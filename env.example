# ClientFlash AI - Variables d'environnement
# Copiez ce fichier en .env.local et remplissez avec vos vraies clés

# =================================
# SUPABASE CONFIGURATION
# =================================
# URL de votre projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Clé anonyme de votre projet Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# =================================
# SÉCURITÉ IMPORTANTE
# =================================
# 1. NE JAMAIS commettre ce fichier sur Git
# 2. Ajouter .env.local à .gitignore
# 3. Utiliser des clés fortes et uniques
# 4. Ne pas utiliser les clés en production dans le code

# =================================
# INSTRUCTIONS D'INSTALLATION
# =================================
# 1. Copiez ce fichier vers .env.local :
#    cp env.example .env.local
#
# 2. Remplacez les valeurs par vos vraies clés Supabase
#
# 3. Redémarrez le serveur de développement
#
# 4. Vérifiez que les variables sont bien chargées

# =================================
# OÙ TROUVER VOS CLÉS SUPABASE
# =================================
# 1. Connectez-vous à https://supabase.com
# 2. Allez dans votre projet
# 3. Settings > API
# 4. Copiez l'URL et la clé anonyme
# 5. Collez-les dans ce fichier

# =================================
# SÉCURITÉ AVANCÉE (Optionnel)
# =================================
# Pour une sécurité maximale en production, vous pouvez aussi configurer :
# NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# SUPABASE_SERVICE_ROLE_KEY=your_private_service_role_key

# =================================
# DÉBOGAGE
# =================================
# Pour vérifier que les variables sont bien chargées, décommentez :
# console.log('Supabase URL:', process.env.NEXT_PUBLIC_SUPABASE_URL)
# console.log('Supabase Key:', process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY ? 'Configured' : 'Missing')
